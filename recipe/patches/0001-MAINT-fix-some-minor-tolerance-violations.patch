From e8643bfe0089e012610f2290c228968c36d2eb36 Mon Sep 17 00:00:00 2001
From: "H. Vetinari" <h.vetinari@gmx.com>
Date: Wed, 27 May 2026 15:09:27 +1100
Subject: [PATCH] MAINT: fix some minor tolerance violations

---
 scipy/interpolate/tests/test_bary_rational.py | 2 +-
 scipy/special/tests/test_log1mexp.py          | 2 +-
 scipy/stats/tests/test_kdeoth.py              | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/scipy/interpolate/tests/test_bary_rational.py b/scipy/interpolate/tests/test_bary_rational.py
index 3baeaf1903..b301d4a160 100644
--- a/scipy/interpolate/tests/test_bary_rational.py
+++ b/scipy/interpolate/tests/test_bary_rational.py
@@ -266,7 +266,7 @@ class TestAAA:
         r = AAA(z, f)
 
         zz = np.logspace(-15, 0, 500)
-        assert_allclose(r(zz), np.sqrt(zz), rtol=9e-6)
+        assert_allclose(r(zz), np.sqrt(zz), rtol=1e-5)
 
 
 class BatchFloaterHormann:
diff --git a/scipy/special/tests/test_log1mexp.py b/scipy/special/tests/test_log1mexp.py
index 5137a82d3f..ed8b1958ea 100644
--- a/scipy/special/tests/test_log1mexp.py
+++ b/scipy/special/tests/test_log1mexp.py
@@ -67,7 +67,7 @@ from scipy.special._ufuncs import _log1mexp
 )
 def test_log1mexp(x, expected):
     observed = _log1mexp(x)
-    assert_allclose(observed, expected, rtol=1e-15)
+    assert_allclose(observed, expected, rtol=1e-15, atol=1e-300)
 
 
 @pytest.mark.parametrize("x", [1.1, 1e10, np.inf])
diff --git a/scipy/stats/tests/test_kdeoth.py b/scipy/stats/tests/test_kdeoth.py
index 31c5bd3757..35b2edce22 100644
--- a/scipy/stats/tests/test_kdeoth.py
+++ b/scipy/stats/tests/test_kdeoth.py
@@ -181,7 +181,7 @@ def test_kde_2d_weighted(n_basesample):
     assert_allclose(
         gkde(xx.T),
         np.sum(pdf(arg, cov=gkde.covariance) * gkde.weights, axis=-1),
-        rtol=5e-14
+        rtol=6e-14
     )
 
     # ... and cdf
